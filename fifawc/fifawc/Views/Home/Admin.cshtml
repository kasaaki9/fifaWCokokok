@model List<fifawc.Models.Player>

@{
    ViewData["Title"] = "Quản lý cầu thủ";
}

<link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />

<div class="admin">

    <div class="title">

        <h1>⚽ Football Rating Admin</h1>

        <a asp-action="Create" class="add-btn">

            <i class="fa-solid fa-plus"></i>

            Thêm cầu thủ

        </a>

    </div>

    <table>

        <thead>

            <tr>

                <th>Ảnh</th>

                <th>Tên</th>

                <th>OVR</th>

                <th>Vị trí</th>

                <th>Thao tác</th>

            </tr>

        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr>

                    <td>

                        <img src="~/images/@item.Image">

                    </td>

                    <td>@item.Name</td>

                    <td>

                        <span class="ovr">

                            @item.OVR

                        </span>

                    </td>

                    <td>@item.Position</td>

                    <td>

                        <a asp-action="Edit"
                           asp-route-id="@item.Id"
                           class="edit">

                            <i class="fa-solid fa-pen"></i>

                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@item.Id"
                           class="delete">

                            <i class="fa-solid fa-trash"></i>

                        </a>


                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>
